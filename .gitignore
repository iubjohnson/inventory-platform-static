# Screenshots & local renders
*.png
*.jpg
*.jpeg

# ...but DO track committed docs screenshots (shipped assets the docs HTML references)
!docs/assets/screenshots/*.png
!docs/assets/screenshots/*.jpg
!docs/assets/screenshots/*.jpeg

# OS / editor cruft
.DS_Store
Thumbs.db
.vscode/
.idea/
*.swp

# Dependencies (if you add a build step later)
node_modules/
dist/
.cache/

# Env / secrets — never commit these
.env
.env.*
*.key
*.pem
